# pfd-saas — example environment configuration.
# Copy to .env.local for local development; never commit the local file.

# Postgres connection. Local default; production should use a managed PG URL.
DATABASE_URL=postgresql://<user>@localhost:5432/pfd_saas

# Auth.js session signing key. Generate fresh per environment:
#   openssl rand -base64 32
AUTH_SECRET=<generate-a-random-32-byte-string>

# Canonical URL for magic-link callbacks. Match your dev port (3000 in
# Sprint 1) or production https host.
NEXTAUTH_URL=http://localhost:3000

# Magic-link email — Sprint 1 stubs the send and logs the URL to the dev
# console + tmp/magic-links.log. EMAIL_SERVER is read by Auth.js but
# ignored by the stub; set both to anything for now. Real SMTP wires in
# Sprint 5.
EMAIL_SERVER=
EMAIL_FROM=noreply@pfd-saas.local
