# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database — lives locally, backed up to OneDrive via BACKUP_DIR.
# Never committed; the schema lives in src/db/schema.ts.
personal-finance.db
*.db-shm
*.db-wal

# Local Claude / Playwright workspace
.claude/
.playwright-mcp/

# Orchestrator workspace
ORCHESTRATOR_CONTEXT.md

# User uploads
/uploads

# Database backups (generated daily)
/backups

# Bundle tarballs from scripts/backup-all.sh
finance-bundle-*.tar.gz

# Service logs (regenerated at runtime)
/logs

# Ad-hoc DB snapshots created during fixes/restores
personal-finance.db.bak-*
personal-finance.db.pre-restore-*
